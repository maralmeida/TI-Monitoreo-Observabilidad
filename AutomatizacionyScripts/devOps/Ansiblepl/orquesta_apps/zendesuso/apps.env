# archivo de muestra de variables de entorno para las aplicaciones de sitios e inventario

# en producción se usa el encriptado, no este archivo.
# clave de encriptacion de archivo se guarda en secrets de github, se sube el archivo encriptado a github, 
# y todo se desencripta en el pipeline de github actions para usarlo en la app.

# Variables comunes para ambas
DB_HOST=192.168.200.38
DB_PORT=1433


# Variables específicas App sitios
SITIOS_DB_USER=sitioapp_php
SITIOS_DB_USER_PASSWORD=sitioapp_php

# Variables específicas de la App Inventario
REGISTRO_DB_USER=usuario_php
REGISTRO_DB_USER_PASSWORD=usuario_php